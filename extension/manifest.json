{
  "manifest_version": 3,
  "name": "Chrome Open with mpv",
  "version": "0.1.0",
  "description": "Open the current Brave tab, embedded media, or selected link in mpv.",
  "key": "",
  "permissions": [
    "activeTab",
    "contextMenus",
    "scripting",
    "nativeMessaging",
    "tabs"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Open current tab in mpv",
    "default_icon": "icons/mpv.png"
  }
}
